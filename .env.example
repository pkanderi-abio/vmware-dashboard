# ─── VMware Dashboard — Environment Configuration Template ──────────────────────
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.

# ─── Backend API (FastAPI) ────────────────────────────────────────────────────

# The hostname/IP of the machine running this service (used for CORS and docs)
# Example: VM_SERVER_HOST=192.168.1.100
VM_SERVER_HOST=localhost

# Port the FastAPI server listens on
VM_SERVER_PORT=8000

# CORS allowed origins for the frontend (comma-separated)
# Example: VM_ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
VM_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Log level: DEBUG | INFO | WARNING | ERROR
VM_LOG_LEVEL=INFO

# ─── PuppetDB Integration ─────────────────────────────────────────────────────
# Full base URL for the PuppetDB REST API v4 endpoint
# Example: PUPPETDB_URL=https://puppetdb.example.com:8081/pdb/query/v4
PUPPETDB_URL=https://your-puppetdb-host:8081/pdb/query/v4

# ─── Vite Dev / Preview Proxy ────────────────────────────────────────────────
# Backend origin to proxy /api/* calls to during `vite dev` and `vite preview`
# Example: API_URL=http://192.168.1.100:8000
API_URL=http://localhost:8000

# ─── Cache ────────────────────────────────────────────────────────────────────
# How long (seconds) cached vCenter data is considered fresh before a refresh
# Default: 1800 (30 minutes)
# VM_CACHE_TTL=1800
